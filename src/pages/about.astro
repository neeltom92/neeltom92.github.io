---
import Base from "../layouts/Base.astro";

const description =
  "Neel Thomas Thelly — Senior DevOps / SRE / AIOps engineer based in Arizona, USA. 10+ years across Kubernetes, observability and AI infrastructure, shipping for companies in India, UAE, France and the US.";

// Companies I helped scale.
const scaled = [
  { co: "Life360", loc: "San Mateo, US", href: "https://www.life360.com/",
    desc: "Publicly traded family-safety company with 60M+ members worldwide." },
  { co: "Ola Cabs", loc: "Bangalore, IN", href: "https://www.olacabs.com/",
    desc: "Mobility startup valued at $6B." },
  { co: "Careem", loc: "Dubai, AE", href: "https://www.careem.com/",
    desc: "Ride-hailing super-app — an Uber company." },
  { co: "Scaleway", loc: "Paris, FR", href: "https://www.scaleway.com/en/",
    desc: "Europe's 2nd-largest cloud provider." },
];

// Companies where I built the infrastructure and DevOps/SRE practice from zero.
const built = [
  { co: "Zolve", loc: "US · IN", href: "https://zolve.com/",
    desc: "Neobank valued at $210M — full cloud + Kubernetes platform from scratch." },
  { co: "Arcab", loc: "Dubai, AE", href: "https://arcab.ae/",
    desc: "Mobility company — greenfield infrastructure and delivery pipelines." },
  { co: "Dview", loc: "Remote", href: "https://dview.io",
    desc: "Data platform pitched as a Fivetran / Hevo alternative." },
];

// whoami terminal session — the hero signature.
const session = [
  { cmd: "whoami",
    out: 'Neel Thomas Thelly — senior <b>devops</b> · <b>sre</b> · <b>aiops</b> engineer' },
  { cmd: "pwd",
    out: "Mesa, AZ · remote" },
  { cmd: "uptime",
    out: "10+ years · 100M+ users served · 4 countries shipped" },
  { cmd: "stack --top",
    out: "kubernetes · observability · AI infra (MCP · LLM agents)" },
];
---

<Base title="About · Neel Thomas Thelly" description={description}>
  <section class="about">
    <div class="wrap">
      <p class="eyebrow reveal">Profile · whoami</p>
      <h1 class="about__title reveal" data-d="1">About</h1>

      <!-- signature: live terminal session -->
      <div class="term reveal" data-d="2" role="img"
           aria-label="Terminal: whoami returns Neel Thomas Thelly, a senior DevOps, SRE and AIOps engineer based in Mesa, Arizona with 10+ years of experience.">
        <div class="term__bar" aria-hidden="true">
          <span class="term__dot"></span><span class="term__dot"></span><span class="term__dot"></span>
          <span class="term__name">profile.sh</span>
        </div>
        <div class="term__body" aria-hidden="true">
          {session.map((l) => (
            <Fragment>
              <p class="term__line">
                <span class="term__prompt">neel@codeworks</span><span class="term__sep">:</span><span class="term__path">~</span><span class="term__sep">$</span> <span class="term__cmd">{l.cmd}</span>
              </p>
              <p class="term__out" set:html={`→ ${l.out}`}></p>
            </Fragment>
          ))}
          <p class="term__line"><span class="term__prompt">neel@codeworks</span><span class="term__sep">:</span><span class="term__path">~</span><span class="term__sep">$</span> <span class="term__caret" aria-hidden="true"></span></p>
        </div>
      </div>

      <p class="about__lead reveal" data-d="3">
        Over a decade in, I keep large-scale cloud-native systems reliable —
        and I'm now putting LLMs to work inside production SRE workflows through
        MCP and AIOps. The journey started at
        <a href="https://bobcares.com/" target="_blank" rel="noopener">Bobcares</a>,
        and has since run through teams in India 🇮🇳, the UAE 🇦🇪,
        France 🇫🇷 and the US 🇺🇸.
      </p>
    </div>
  </section>

  <!-- scaled -->
  <section class="sec" id="scaled">
    <div class="wrap">
      <p class="eyebrow reveal">Operated at scale · uptime log</p>
      <h2 class="sec__title reveal" data-d="1">Companies I helped scale</h2>
      <p class="sec__intro reveal" data-d="2">
        Established platforms where I owned reliability, observability and
        delivery as they grew.
      </p>

      <div class="proj-grid">
        {scaled.map((c, i) => (
          <article class="proj reveal" data-d={String((i % 2) + 1)}>
            <span class="proj__tag"><span class="led"></span> {c.loc}</span>
            <h3 class="proj__title">{c.co}</h3>
            <p class="proj__desc">{c.desc}</p>
            <a class="proj__link" href={c.href} target="_blank" rel="noopener" aria-label={`${c.co} website`}>↗</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- built from scratch -->
  <section class="sec" id="built">
    <div class="wrap">
      <p class="eyebrow reveal">Greenfield · provisioned from zero</p>
      <h2 class="sec__title reveal" data-d="1">Built from scratch</h2>
      <p class="sec__intro reveal" data-d="2">
        Founding-level work: I stood up the entire infrastructure and embedded
        the DevOps / SRE practice from day one.
      </p>

      <div class="proj-grid">
        {built.map((c, i) => (
          <article class="proj reveal" data-d={String((i % 2) + 1)}>
            <span class="proj__tag proj__tag--oss"><span class="led"></span> {c.loc}</span>
            <h3 class="proj__title">{c.co}</h3>
            <p class="proj__desc">{c.desc}</p>
            <a class="proj__link" href={c.href} target="_blank" rel="noopener" aria-label={`${c.co} website`}>↗</a>
          </article>
        ))}
      </div>

      <p class="tl__legend reveal">
        ▮ Also ran DevOps advisory for SaaS portfolio companies under
        <a href="https://together.fund/" target="_blank" rel="noopener" class="about__inline-link">Together Fund</a>.
      </p>
    </div>
  </section>

  <!-- next -->
  <section class="sec" id="about-next">
    <div class="wrap">
      <p class="eyebrow reveal">Next</p>
      <h2 class="sec__title reveal" data-d="1">See the work</h2>
      <div class="btn-row reveal" data-d="2">
        <a class="btn btn--primary" href="/projects/">View projects</a>
        <a class="btn" href="/resume/">Résumé</a>
        <a class="btn" href="mailto:neeltom92@gmail.com">Get in touch ↗</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* page top spacing — mirrors hero rhythm without a full hero */
  .about { padding: clamp(3.5rem, 9vw, 6.5rem) 0 clamp(2rem, 5vw, 3rem); }
  .about__title {
    font-weight: 800; letter-spacing: -0.04em; text-transform: uppercase;
    font-size: clamp(2.6rem, 7vw, 4.5rem); line-height: 0.92;
    margin-bottom: clamp(1.6rem, 4vw, 2.4rem);
  }
  .about__lead {
    color: var(--ink-2); max-width: 46rem; font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.6; margin-top: clamp(1.6rem, 4vw, 2.2rem);
  }
  .about__lead a, .about__inline-link {
    color: var(--accent-ink); border-bottom: 1px solid var(--accent-dim);
    transition: border-color 0.16s ease;
  }
  .about__lead a:hover, .about__inline-link:hover { border-bottom-color: var(--accent); }

  /* ---- signature: terminal session ---- */
  .term {
    max-width: 44rem; border: 1px solid var(--line); border-radius: 14px;
    overflow: hidden; background: linear-gradient(180deg, var(--bg-elev), var(--bg-sunk));
    font-family: var(--mono); box-shadow: 0 24px 50px -34px rgba(0, 0, 0, 0.9);
  }
  .term__bar {
    display: flex; align-items: center; gap: 0.45rem;
    padding: 0.7rem 1.05rem; border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
  }
  .term__dot { width: 9px; height: 9px; border-radius: 50%; background: var(--faint); }
  .term__dot:first-child { background: var(--accent); }
  .term__name {
    margin-left: auto; font-size: 0.66rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--muted);
  }
  .term__body { padding: 1.1rem 1.2rem 1.25rem; font-size: 0.85rem; line-height: 1.5; }
  .term__line { color: var(--ink); }
  .term__line + .term__out { margin-top: 0.15rem; }
  .term__prompt { color: var(--accent-deep); }
  .term__sep { color: var(--faint); }
  .term__path { color: var(--muted); }
  .term__cmd { color: var(--ink); }
  .term__out {
    color: var(--ink-2); margin: 0 0 0.85rem 0.1rem; padding-left: 0.9rem;
  }
  .term__out b { color: var(--accent-ink); font-weight: 500; }
  .term__caret {
    display: inline-block; width: 0.55rem; height: 1rem; vertical-align: -0.15rem;
    background: var(--accent); animation: termBlink 1.1s steps(1) infinite;
  }
  @keyframes termBlink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .term__caret { animation: none; } }

  /* company cards have no idx/sequence — keep title clear of the corner */
  .about ~ .sec .proj { padding-top: 1.6rem; }
</style>
