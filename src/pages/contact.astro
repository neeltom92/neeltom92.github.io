---
import Base from "../layouts/Base.astro";

const resumeVersion = (import.meta.env.PUBLIC_GIT_SHA || "dev").slice(0, 7);
const resume = `/resume.pdf?v=${resumeVersion}`;
const resumeView = "/resume/";
const description =
  "Get in touch with Neel Thomas Thelly — email, LinkedIn, GitHub. Open to senior SRE, platform and AI-infrastructure roles.";

const channels = [
  { k: "Email", v: "neeltom92@gmail.com", href: "mailto:neeltom92@gmail.com", ext: false },
  { k: "LinkedIn", v: "in/neel-thomas-thelly", href: "https://www.linkedin.com/in/neel-thomas-thelly-646a27131/", ext: true },
  { k: "GitHub", v: "@neeltom92", href: "https://github.com/neeltom92", ext: true },
  { k: "Medium", v: "@neeltom92", href: "https://medium.com/@neeltom92", ext: true },
  { k: "X / Twitter", v: "@NEELTHOMAS11", href: "https://twitter.com/NEELTHOMAS11", ext: true },
  { k: "Résumé", v: "view online", href: resumeView, ext: false },
];
---

<Base title="Contact · Neel Thomas Thelly" description={description}>
  <section class="contact">
    <div class="wrap">
      <div class="contact__grid">
        <div>
          <p class="eyebrow">Contact · channels</p>
          <h1 class="contact__title">Let's talk<br>reliability</h1>
          <p class="sec__intro">
            Open to senior SRE, platform and AI-infrastructure roles. Email is the
            fastest way to reach me; I'm also around on the channels below.
          </p>
          <p class="contact__live"><span class="nav__dot" aria-hidden="true"></span> available · usually replies within a day · Mesa, AZ · remote</p>

          <div class="btn-row" style="margin-top:2rem">
            <a class="btn btn--primary" href="mailto:neeltom92@gmail.com">Email me</a>
            <a class="btn" href="https://www.linkedin.com/in/neel-thomas-thelly-646a27131/" target="_blank" rel="noopener">Connect on LinkedIn ↗</a>
            <a class="btn" href={resume} download="Neel_Thomas_Thelly_Resume.pdf">↓ Download résumé</a>
          </div>
        </div>

        <div class="panel" aria-label="contact channels">
          <div class="panel__head"><span class="nav__dot" aria-hidden="true" style="animation:none"></span> reach me</div>
          {channels.map((c) => (
            <a class="chan" href={c.href} {...(c.ext ? { target: "_blank", rel: "noopener" } : {})}>
              <span class="chan__k">{c.k}</span>
              <span class="chan__v">{c.v}</span>
              <span class="chan__go" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
