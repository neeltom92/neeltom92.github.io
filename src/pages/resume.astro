---
import Base from "../layouts/Base.astro";

const resume = "/resume.pdf";
const description = "Résumé of Neel Thomas Thelly — Senior DevOps / SRE / AIOps Engineer.";

const gallery = [
  { src: "/images/gallery/astronaut.jpg", alt: "Astronaut suit cutout at the space center", caption: "Suiting up · Space Center" },
  { src: "/images/gallery/hooverdam.jpg", alt: "At the Hoover Dam bypass bridge", caption: "Hoover Dam bypass bridge" },
  { src: "/images/gallery/grandcanyon.jpg", alt: "Bentonville countryside, Arkansas", caption: "Bentonville countryside, Arkansas" },
];
---

<Base title="Résumé · Neel Thomas Thelly" description={description}>
  <section class="resume">
    <div class="wrap">
      <p class="eyebrow">Document · curriculum vitae</p>
      <h1 class="sec__title" style="margin-bottom:1.6rem">Résumé</h1>

      <div class="resume__grid">
        <div>
          <div class="btn-row" style="margin-bottom:1.1rem">
            <a class="btn btn--primary" href={resume} download="Neel_Thomas_Thelly_Resume.pdf">↓ Download PDF</a>
            <a class="btn" href={resume} target="_blank" rel="noopener">Open raw ↗</a>
          </div>
          <iframe class="resume__frame" src={`${resume}#view=FitH`} title="Résumé of Neel Thomas Thelly" loading="lazy"></iframe>
        </div>

        <aside aria-label="photo gallery">
          <p class="eyebrow">Off-duty · field notes</p>
          <h2 class="sec__title" style="font-size:clamp(1.5rem,3.5vw,2.1rem); margin-bottom:0.5rem">Beyond the terminal</h2>
          <p style="color:var(--ink-2); font-size:0.96rem; margin:0">
            When I'm not keeping systems up: chasing rockets, and exploring the American Southwest.
          </p>

          <div class="gallery">
            {gallery.map((g) => (
              <figure>
                <a href={g.src} target="_blank" rel="noopener">
                  <img src={g.src} alt={g.alt} loading="lazy" />
                </a>
                <figcaption>{g.caption}</figcaption>
              </figure>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>
