---
import "../styles/global.css";

const SITE_TITLE = "Neel Thomas Thelly";
const DEFAULT_DESC =
  "Neel Thomas Thelly — Senior DevOps / SRE / AIOps Engineer with 10+ years building scalable, reliable cloud-native infrastructure. Kubernetes, observability, and AI infrastructure (MCP, LLM agents, AIOps).";
const KEYWORDS =
  "Neel Thomas Thelly, DevOps Engineer, Site Reliability Engineer, SRE, AIOps, Platform Engineer, Kubernetes, AWS, EKS, Observability, Terraform, MCP, AI Infrastructure, LLM agents, Datadog, Prometheus, OpenTelemetry, Arizona, remote";

interface Props {
  title?: string;
  description?: string;
  isHome?: boolean;
}

const { title, description = DEFAULT_DESC, isHome = false } = Astro.props;
const pageTitle = title ?? `${SITE_TITLE} — Senior DevOps / SRE / AIOps Engineer`;

const ogImage = new URL("/images/N90.jpg", Astro.site).href;
const siteUrl = Astro.site?.href ?? "https://codeworks.cloud/";

const navItems = [
  { name: "About", url: "/about/", idx: "01" },
  { name: "Projects", url: "/projects/", idx: "02" },
  { name: "Contact", url: "/contact/", idx: "03" },
  { name: "Resume", url: "/resume/", idx: "04" },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Neel Thomas Thelly",
  url: siteUrl,
  image: ogImage,
  jobTitle: "Senior DevOps / SRE / AIOps Engineer",
  email: "mailto:neeltom92@gmail.com",
  worksFor: { "@type": "Organization", name: "Life360" },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Mesa",
    addressRegion: "AZ",
    addressCountry: "US",
  },
  knowsAbout: [
    "Kubernetes", "Site Reliability Engineering", "DevOps", "Observability",
    "AWS", "Terraform", "AIOps", "Model Context Protocol",
    "Platform Engineering", "OpenTelemetry",
  ],
  sameAs: [
    "https://github.com/neeltom92",
    "https://www.linkedin.com/in/neel-thomas-thelly-646a27131/",
    "https://twitter.com/NEELTHOMAS11",
    "https://medium.com/@neeltom92",
  ],
};

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={KEYWORDS} />
    <meta name="author" content="Neel Thomas Thelly" />
    <meta name="theme-color" content="#0a0e0d" />
    <link rel="canonical" href={Astro.url.href} />

    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />

    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}

    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <!-- atmosphere -->
    <div class="fx-grain" aria-hidden="true"></div>
    <div class="fx-scan" aria-hidden="true"></div>
    <div class="fx-glow" aria-hidden="true"></div>

    <header class="nav">
      <div class="nav__in">
        <a class="nav__brand" href="/">
          <span class="nav__dot" aria-hidden="true"></span>neel<span class="nav__brand-accent">.thelly</span>
        </a>
        <nav class="nav__links" aria-label="primary">
          {navItems.map((item) => (
            <a class="nav__link" href={item.url}>
              <span class="nav__idx">{item.idx}</span>{item.name}
            </a>
          ))}
        </nav>
        <a class="nav__cta" href="mailto:neeltom92@gmail.com">Get in touch ↗</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="foot">
      <div class="foot__in">
        <div class="foot__brand">
          <span class="foot__big">NEEL THOMAS THELLY</span>
          <span class="foot__tag">// reliable systems — now with AI in the loop</span>
        </div>
        <div class="foot__grid">
          <div class="foot__col">
            <span class="foot__k">elsewhere</span>
            <a href="https://github.com/neeltom92" target="_blank" rel="noopener">GitHub ↗</a>
            <a href="https://www.linkedin.com/in/neel-thomas-thelly-646a27131/" target="_blank" rel="noopener">LinkedIn ↗</a>
            <a href="https://medium.com/@neeltom92" target="_blank" rel="noopener">Medium ↗</a>
            <a href="https://twitter.com/NEELTHOMAS11" target="_blank" rel="noopener">X / Twitter ↗</a>
          </div>
          <div class="foot__col">
            <span class="foot__k">direct</span>
            <a href="mailto:neeltom92@gmail.com">neeltom92@gmail.com</a>
            <span class="foot__loc">Mesa, AZ · remote</span>
            <span class="foot__loc"><span class="foot__live"></span> available for work</span>
          </div>
        </div>
        <div class="foot__base">
          <span>© {year} Neel Thomas Thelly</span>
          <span>built with Astro · deployed on Cloudflare</span>
        </div>
      </div>
    </footer>

    <script>
      // cinematic scroll reveal
      const els = document.querySelectorAll<HTMLElement>(".reveal");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("in"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                (e.target as HTMLElement).classList.add("in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        els.forEach((el) => io.observe(el));
      }

      // project cards — cursor-follow phosphor spotlight
      document.querySelectorAll<HTMLElement>(".proj").forEach((card) => {
        card.addEventListener("pointermove", (e) => {
          const r = card.getBoundingClientRect();
          card.style.setProperty("--mx", `${((e.clientX - r.left) / r.width) * 100}%`);
          card.style.setProperty("--my", `${((e.clientY - r.top) / r.height) * 100}%`);
        });
      });

      // hero panel — live p50-latency sparkline (the site monitoring itself)
      const spark = document.querySelector<SVGSVGElement>(".spark");
      if (spark) {
        const line = spark.querySelector<SVGPolylineElement>(".spark__line")!;
        const dot = spark.querySelector<SVGCircleElement>(".spark__dot")!;
        const msEl = document.querySelector<HTMLElement>("[data-ms]");
        const N = 28, W = 240, H = 48, PAD = 5;
        const xOf = (i: number) => (i / (N - 1)) * W;
        const yOf = (v: number) => H - PAD - v * (H - 2 * PAD);
        const sample = () =>
          Math.random() < 0.12 ? 0.82 + Math.random() * 0.14 : 0.26 + Math.random() * 0.32;
        const ms = (v: number) => Math.round(34 + v * 150);
        const render = (arr: number[]) => {
          line.setAttribute(
            "points",
            arr.map((v, i) => `${xOf(i).toFixed(1)},${yOf(v).toFixed(1)}`).join(" ")
          );
          dot.setAttribute("cy", yOf(arr[N - 1]).toFixed(1));
        };
        let data = Array.from({ length: N }, sample);

        if (reduce) {
          render(data);
          if (msEl) msEl.textContent = `${ms(data[N - 1])} ms`;
        } else {
          let from = data.slice();
          let to = data.slice();
          let t0 = performance.now();
          const DUR = 1200;
          const ease = (p: number) => (p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2);
          const push = () => {
            from = to.slice();
            data = data.slice(1);
            data.push(sample());
            to = data.slice();
            t0 = performance.now();
            if (msEl) msEl.textContent = `${ms(to[N - 1])} ms`;
          };
          const frame = (now: number) => {
            const e = ease(Math.min(1, (now - t0) / DUR));
            render(from.map((v, i) => v + (to[i] - v) * e));
            requestAnimationFrame(frame);
          };
          push();
          setInterval(push, DUR);
          requestAnimationFrame(frame);
        }
      }
    </script>
  </body>
</html>
